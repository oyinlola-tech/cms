PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=mysql
DB_NAME=church_db

# Auth
# Generate a long random value (32+ chars). Never use the default in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Default admin (created by db-init.js on first run if it doesn't exist)
ADMIN_NAME=Parish Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Optional: restrict cross-origin calls in production (comma-separated)
# Example: CORS_ORIGIN=https://cms.yourchurch.org
CORS_ORIGIN=

# SMTP (only used when NODE_ENV=production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sacred Hearth CMS" <noreply@example.com>

